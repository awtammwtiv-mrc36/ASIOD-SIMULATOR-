{
  "system": "ASIOD_COMMERCIAL_GATEWAY",
  "version": "0.1.0",
  "purpose": "Convert ASIOD Information Bridge traffic into contracted paid access before full simulator-backed verification is performed.",
  "business_flow": [
    "receive_external_ai_or_client_material",
    "return_limited_corrected_bridge_response",
    "offer_contract_for_full_verification",
    "collect_payment_or_deposit",
    "issue_client_access_key",
    "meter_usage",
    "deliver_signed_correction_receipts",
    "invoice_or_charge_overages",
    "revoke_access_only_under_contract_terms"
  ],
  "before_payment": {
    "allowed": [
      "limited_public_bridge_summary",
      "high_level_error_classification",
      "service_offer",
      "pricing_or_quote",
      "contract_request"
    ],
    "not_allowed": [
      "full_private_validation",
      "full simulator-backed correction",
      "private_14_field_source_exposure",
      "full proof package delivery",
      "unmetered client access"
    ]
  },
  "after_payment": {
    "allowed": [
      "full claim extraction",
      "simulator-backed verification",
      "correction report",
      "public receipt",
      "private contracted receipt where permitted",
      "API key access",
      "usage metering"
    ]
  },
  "payment_models": {
    "single_report": "one paid correction report",
    "subscription": "monthly access to correction gateway",
    "api_meter": "pay per claim, document, or receipt",
    "enterprise_contract": "custom contract with usage limits and support",
    "deposit_then_work": "payment taken before full private validation"
  },
  "access_control": {
    "client_id_required": true,
    "api_key_required_after_contract": true,
    "usage_meter_required": true,
    "revocation": "only_for_non_payment_breach_or_contract_terms"
  },
  "private_14_field_body_publicly_displayed": false,
  "status": "COMMERCIAL_GATEWAY_READY"
}
