{
  "system": "ASIOD_FUNDS_DASHBOARD",
  "version": "0.1.0",
  "purpose": "Display payment processor balances and payout state for ASIOD paid services.",
  "funds_source": "payment_processor_balance_api",
  "bank_account_role": "funds_payout_stripe_pay_only",
  "bank_details_stored_in_repo": false,
  "secret_keys_stored_in_repo": false,
  "display_fields": [
    "available_balance",
    "pending_balance",
    "currency",
    "last_payment_received",
    "last_payout_status",
    "open_paid_jobs",
    "receipts_issued"
  ],
  "payment_chain": [
    "client_or_ai_agent_requests_service",
    "payment_processor_collects_payment",
    "paid_access_or_job_id_is_issued",
    "service_is_delivered",
    "receipt_is_issued",
    "funds_settle_to_stripe_pay_account"
  ],
  "status": "FUNDS_DISPLAY_READY_FOR_PAYMENT_ STRIPE_ PAY"
}
